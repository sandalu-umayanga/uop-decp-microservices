# DECP Microservices Environment Configuration
# Copy this file to .env and update the values with your own

# PostgreSQL
POSTGRES_USER=decp_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=decp_db

# MongoDB
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=change_me
MONGO_HOST=localhost
MONGO_PORT=27018
MONGO_DB=decp_posts
SPRING_DATA_MONGODB_URI=mongodb://admin:change_me@localhost:27018/decp_posts?authSource=admin
SPRING_DATA_MONGODB_URI_MESSAGING=mongodb://admin:change_me@localhost:27018/decp_messaging?authSource=admin
SPRING_DATA_MONGODB_URI_NOTIFICATION=mongodb://admin:change_me@localhost:27018/decp_notifications?authSource=admin
SPRING_DATA_MONGODB_URI_PROD=mongodb://admin:change_me@mongodb:27017/decp_posts?authSource=admin

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=change_me
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
SPRING_RABBITMQ_HOST=localhost
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=guest
SPRING_RABBITMQ_PASSWORD=change_me
SPRING_RABBITMQ_HOST_PROD=rabbitmq

# JWT
JWT_SECRET=change_me_with_a_secure_key
JWT_EXPIRATION=86400000

# CORS (set to your frontend URL in production, e.g. http://ec2-ip:3000)
CORS_ALLOWED_ORIGIN=http://localhost:3000
